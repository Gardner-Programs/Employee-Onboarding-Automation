# Path to your Google service account key JSON file.
KEY_PATH=/path/to/Keys/service-account-key.json

# Admin Google Workspace email used for API delegation.
ADMIN_EMAIL=admin@yourdomain.com

# Default password assigned to new employee accounts on first login.
DEFAULT_EMP_PASSWORD=Welcome1!

# Transport Pro login credentials (used by CLI version with 2FA automation).
TPASSWORD=your_tp_password

# Terminal IDs for the Branch A (HQ) routing logic in data_processing.py.
# HQ_PARENT_TERMINAL_ID is the parent terminal that new hires should NOT be assigned to directly.
# HQ_ADMIN_FALLBACK_ID is the terminal used when no department match is found.
HQ_PARENT_TERMINAL_ID=YOUR_PARENT_TERMINAL_ID
HQ_ADMIN_FALLBACK_ID=YOUR_FALLBACK_TERMINAL_ID
